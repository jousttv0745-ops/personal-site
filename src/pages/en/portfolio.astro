---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title="Portfolio — Tu, Wei-Hua" lang="en" page="portfolio">

  <!-- Page header -->
  <div class="pt-4 mb-12">
    <p class="section-label mb-4">Selected Work</p>
    <h1 class="text-5xl font-bold tracking-tight text-[#0a0a0a] leading-none">Portfolio</h1>
  </div>

  <!-- Project -->
  <div class="rule-strong">
    <div class="project-card">

      <!-- Card header -->
      <button
        class="w-full text-left py-8 flex items-start justify-between gap-6 group"
        aria-expanded="false"
        aria-controls="detail-keyword"
      >
        <div class="flex items-start gap-6 flex-1 min-w-0">
          <span class="section-label pt-1 shrink-0 w-6">01</span>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-1.5 flex-wrap">
              <h3 class="text-lg font-semibold text-[#0a0a0a] group-hover:text-blue-600 transition-colors">
                High-Potential Ad Keyword Selection Tool
              </h3>
              <span class="text-[10px] font-semibold uppercase tracking-[0.1em] text-zinc-400 border border-zinc-200 px-2 py-0.5 rounded-sm shrink-0">
                Internal Tool
              </span>
            </div>
            <p class="text-sm text-zinc-500 leading-relaxed">
              Built with Claude skill + Looker Studio to help ad sales, planners, and marketing teams query site traffic data, auto-shortlist high-potential keywords, and generate GAM targeting lists with placement recommendations — significantly reducing manual prep time.
            </p>
          </div>
        </div>
        <span class="chevron mt-1 text-zinc-300 shrink-0 transition-transform duration-200">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <!-- Expandable detail -->
      <div id="detail-keyword" class="detail-panel hidden pb-10 pl-12 border-t border-zinc-100">

        <!-- Meta grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

          <div>
            <p class="section-label mb-3">My Role</p>
            <p class="text-sm text-zinc-600 leading-relaxed">Owner</p>
          </div>

          <div>
            <p class="section-label mb-3">Outcomes</p>
            <ul class="space-y-2">
              {[
                'Ops time cut by 60%',
                'Adopted by more than 2 departments',
              ].map(o => (
                <li class="flex items-start gap-3 text-sm text-zinc-600">
                  <span class="mt-2 h-px w-3 bg-zinc-300 shrink-0"></span>
                  {o}
                </li>
              ))}
            </ul>
          </div>

          <div>
            <p class="section-label mb-3">Tools / Stack</p>
            <div class="flex flex-wrap gap-2">
              {['SQL', 'Looker Studio', 'Claude API'].map(t => (
                <span class="px-2.5 py-1 text-xs font-medium border border-zinc-200 text-zinc-600 rounded-sm">{t}</span>
              ))}
            </div>
          </div>

        </div>

        <!-- Demo screenshots — two-column, below meta -->
        <div class="grid grid-cols-2 gap-3 mt-8">
          <div class="rounded-sm overflow-hidden border border-zinc-200">
            <div class="px-3 py-1.5 bg-zinc-50 border-b border-zinc-200">
              <span class="section-label">Step 1 — Looker Studio</span>
            </div>
            <img
              src={`${base}assets/keyword-demo-1.png`}
              alt="Looker Studio keyword traffic distribution dashboard"
              class="w-full object-cover"
              onerror="this.closest('.rounded-sm').style.display='none'"
            />
          </div>
          <div class="rounded-sm overflow-hidden border border-zinc-200">
            <div class="px-3 py-1.5 bg-zinc-50 border-b border-zinc-200">
              <span class="section-label">Step 2 — Claude AI</span>
            </div>
            <img
              src={`${base}assets/keyword-demo-2.png`}
              alt="Claude AI conversation generating ad keyword targeting plan"
              class="w-full object-cover"
              onerror="this.closest('.rounded-sm').style.display='none'"
            />
          </div>
        </div>

      </div>
    </div>

    <!-- Project 02 -->
    <div class="project-card border-t border-zinc-100">

      <button
        class="w-full text-left py-8 flex items-start justify-between gap-6 group"
        aria-expanded="false"
        aria-controls="detail-web"
      >
        <div class="flex items-start gap-6 flex-1 min-w-0">
          <span class="section-label pt-1 shrink-0 w-6">02</span>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-1.5 flex-wrap">
              <h3 class="text-lg font-semibold text-[#0a0a0a] group-hover:text-blue-600 transition-colors">
                Website Redesign Projects
              </h3>
              <span class="text-[10px] font-semibold uppercase tracking-[0.1em] text-zinc-400 border border-zinc-200 px-2 py-0.5 rounded-sm shrink-0">
                Project Management
              </span>
            </div>
            <p class="text-sm text-zinc-500 leading-relaxed">
              Led planning and project management for two website redesigns, covering brand visual refresh, UX optimization, new feature development, and content strategy.
            </p>
          </div>
        </div>
        <span class="chevron mt-1 text-zinc-300 shrink-0 transition-transform duration-200">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <div id="detail-web" class="detail-panel hidden pb-10 pl-12 border-t border-zinc-100">

        <!-- Project descriptions -->
        <div class="mt-6 mb-8 space-y-4">
          <div>
            <p class="text-xs font-semibold text-blue-600 uppercase tracking-[0.1em] mb-1.5">National Human Rights Museum — Official Website Redesign</p>
            <p class="text-sm text-zinc-600 leading-relaxed">
              Participated in the full redesign of the museum's website and brand visual identity (2021/05–2022/01). Led project scoping and management, defining the brand rejuvenation direction, UX improvements, and design-development specifications.
            </p>
          </div>
          <div>
            <p class="text-xs font-semibold text-blue-600 uppercase tracking-[0.1em] mb-1.5">2025 Talent, in Taiwan — Sustainability Action Alliance</p>
            <p class="text-sm text-zinc-600 leading-relaxed">
              Covered content agenda-setting, advocacy review, and new feature development (2024/11–2025/03). Drove SEO improvements, dedicated page planning and design-development, and overall content experience optimization.
            </p>
          </div>
        </div>

        <!-- Meta grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

          <div>
            <p class="section-label mb-3">My Role</p>
            <p class="text-sm text-zinc-600 leading-relaxed">Owner</p>
          </div>

          <div>
            <p class="section-label mb-3">Outcomes</p>
            <ul class="space-y-2">
              {['Both redesigns launched on schedule'].map(o => (
                <li class="flex items-start gap-3 text-sm text-zinc-600">
                  <span class="mt-2 h-px w-3 bg-zinc-300 shrink-0"></span>
                  {o}
                </li>
              ))}
            </ul>
          </div>

          <div>
            <p class="section-label mb-3">Tools / Skills</p>
            <div class="flex flex-wrap gap-2">
              {['Project Management', 'Brand Strategy', 'SEO', 'UX Planning', 'Design-Dev Coordination', 'Figma'].map(t => (
                <span class="px-2.5 py-1 text-xs font-medium border border-zinc-200 text-zinc-600 rounded-sm">{t}</span>
              ))}
            </div>
          </div>

        </div>

        <!-- Demo screenshots -->
        <div class="grid grid-cols-2 gap-3 mt-8">
          <div class="rounded-sm overflow-hidden border border-zinc-200">
            <div class="px-3 py-1.5 bg-zinc-50 border-b border-zinc-200">
              <span class="section-label">National Human Rights Museum</span>
            </div>
            <img
              src={`${base}assets/web-demo-1.png`}
              alt="National Human Rights Museum website redesign"
              class="w-full object-cover"
              onerror="this.closest('.rounded-sm').style.display='none'"
            />
          </div>
          <div class="rounded-sm overflow-hidden border border-zinc-200">
            <div class="px-3 py-1.5 bg-zinc-50 border-b border-zinc-200">
              <span class="section-label">Talent, in Taiwan</span>
            </div>
            <img
              src={`${base}assets/web-demo-2.png`}
              alt="Talent in Taiwan project page"
              class="w-full object-cover"
              onerror="this.closest('.rounded-sm').style.display='none'"
            />
          </div>
        </div>

      </div>
    </div>
  </div>

</Layout>

<script>
  // Expand / collapse cards
  document.querySelectorAll<HTMLButtonElement>('.project-card button').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const panel = document.getElementById(btn.getAttribute('aria-controls')!);
      const chevron = btn.querySelector<HTMLElement>('.chevron');
      btn.setAttribute('aria-expanded', String(!expanded));
      panel?.classList.toggle('hidden', expanded);
      if (chevron) chevron.style.transform = expanded ? '' : 'rotate(180deg)';
    });
  });

  // Lightbox
  const overlay = document.createElement('div');
  overlay.style.cssText = `
    display:none; position:fixed; inset:0; z-index:9999;
    background:rgba(0,0,0,0.85); cursor:zoom-out;
    align-items:center; justify-content:center;
    transition:opacity 0.15s ease;
  `;
  const img = document.createElement('img');
  img.style.cssText = 'max-width:90vw; max-height:90vh; object-fit:contain; border-radius:2px;';
  overlay.appendChild(img);
  document.body.appendChild(overlay);

  function openLightbox(src: string, alt: string) {
    img.src = src;
    img.alt = alt;
    overlay.style.display = 'flex';
    overlay.style.opacity = '0';
    requestAnimationFrame(() => { overlay.style.opacity = '1'; });
  }

  function closeLightbox() {
    overlay.style.opacity = '0';
    setTimeout(() => { overlay.style.display = 'none'; }, 150);
  }

  overlay.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

  document.querySelectorAll<HTMLImageElement>('.detail-panel img').forEach(imgEl => {
    imgEl.style.cursor = 'zoom-in';
    imgEl.addEventListener('click', (e) => {
      e.stopPropagation();
      openLightbox(imgEl.src, imgEl.alt);
    });
  });
</script>
