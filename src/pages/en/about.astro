---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="About — Tu, Wei-Hua" lang="en" page="about">

  <!-- Name -->
  <div class="mb-3">
    <p class="section-label mb-4">About</p>
    <h1 class="text-6xl font-bold tracking-tight leading-none">Tu,&nbsp;Wei&#8209;Hua</h1>
  </div>

  <div class="rule-strong mt-8 mb-10"></div>

  <!-- Bio -->
  <p class="text-base text-zinc-600 leading-relaxed max-w-2xl mb-16">
    Anthropologist-turned strategist focused on audience infrastructure, behavioral systems, and data monetization.
    Experienced in translating complex business and user behavior into scalable operational and cross-functional
    frameworks across media and digital platforms.
  </p>

  <!-- Two-column info grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 border-t-2 border-[#0a0a0a]">

    <div class="py-8 md:border-r border-zinc-200 md:pr-10">
      <p class="section-label mb-4">學歷 Education</p>
      <p class="text-sm font-semibold text-[#0a0a0a]">National Taiwan University</p>
      <p class="text-sm text-zinc-500">M.A. in Anthropology</p>
    </div>

    <div class="py-8 border-t-2 md:border-t-0 border-[#0a0a0a] md:pl-10">
      <p class="section-label mb-4">聯絡 Contact</p>
      <ul class="space-y-1.5 text-sm">
        <li class="text-zinc-500">Taipei, Taiwan</li>
        <li>
          <a href="mailto:jousttv0745@gmail.com"
             class="font-medium text-[#0a0a0a] hover:text-blue-600 transition-colors">
            jousttv0745@gmail.com
          </a>
        </li>
      </ul>
    </div>

  </div>

</Layout>
