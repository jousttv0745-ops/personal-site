---
import Layout from '../../layouts/Layout.astro';

const experience = [
  {
    role: '數據產品經理',
    company: '聯利媒體（TVBS）',
    period: '2025.07 — 現在',
    groups: [
      {
        label: '數據基礎建設 & CDP 治理',
        items: [
          '主導 CDP（mParticle）架構規劃與數據治理機制，建立涵蓋千萬受眾的跨產品基礎建設，提升跨產品追蹤一致性，支援以用戶為核心的分析。',
          '建立與維護數據架構文件，包含身份識別、事件分類與特徵治理，推動組織從品牌分工模式逐步轉向跨產品受眾導向的營運策略。',
          '橫向協調產品、工程、業務、編輯等多方利害關係人，建立 5 大品牌跨部門共同語言，推動 TVBS 網路新聞、健康2.0、女人我最大、食尚玩家、地球黃金線的數據策略。',
        ],
      },
      {
        label: 'Rich Data 受眾洞察產品',
        items: [
          '主導設計結合零方與第一方數據的 Rich Data 受眾框架（涵蓋人口、興趣與消費等數百個特徵）。',
          '定義第一方行為數據所對應的人物特徵，將行為訊號轉化為可被商業與分析應用的受眾洞察。',
          '規劃零方數據（問卷／測驗）與第一方行為訊號的匹配邏輯，提升受眾輪廓及標籤覆蓋率，單季可達約 100 萬貼標量。',
          '建立「追加受眾邏輯」並封裝為 SDK 層級，解決 CDP 系統覆寫限制，降低跨產品實作複雜度。',
          '建立可規模化的商業敘事，支援精準投放、冠名贊助、數據即服務（DaaS）與 Data Clean Room 等未來商業應用彈性。',
        ],
      },
      {
        label: '中心化報表與數據賦能',
        items: [
          '共同持有 GA4 v3 分析架構與中心化儀表板，提升跨部門數據可視化與決策效率。',
          '擔任內部數據顧問，協助管理層、賦能業務與產品團隊受眾策略與數據應用能力。',
        ],
      },
    ],
  },
  {
    role: '數位營運副理、資深撰述',
    company: '天下雜誌學習事業群',
    period: '2022.02 — 2025.03',
    groups: [
      {
        label: '內容營運策略規劃',
        items: [
          '主責近百萬追蹤的內容行銷策略，策動之短影音曾創下單支 30 萬觀看，IG 追蹤單月成長 0.7%。',
          '主責月均流量超過數百萬的內容營運及流量分析，透過 Aiqua 工具、Aixon 受眾分析進行版位操作及 A/B 實驗，網站交易轉換率一個月內由 0.16% 提升至 0.3%。',
          '主責內容 SEO 策略，操作 Ahrefs、SimilarWeb 等工具進行進站趨勢、競品觀測、關鍵字佈局，執行 3 個月後關鍵字 P1 排名達成率超過 50%。',
        ],
      },
      {
        label: '整合資源建立策展論述',
        items: [
          '橫向協調工程、設計、編務及記者資源，建立數位內容策展流程與規範化，每季穩定產出至少 1 次大型專案及 1 次小規模策展。',
          '負責策展論述多次入圍外部獎項，個人曾獲第一屆媒體晚峰會編輯獎肯定。',
        ],
      },
    ],
  },
  {
    role: '媒體公關',
    company: '國家人權博物館',
    period: '2019.10 — 2022.01',
    groups: [
      {
        label: '',
        items: [
          '主責對外公關策略擬定、公關稿撰寫、公關物製作、媒體聯繫與溝通。',
          '主責對外品牌形象論述，與廠商合作執行品牌網站改版標案。',
          '擅長將人權議題轉譯為大眾可理解之論述，期間曾獨自創下 10 萬以上觸及社群文案。',
          '協調政治與意識形態敏感議題中的多方利害關係人溝通與公共敘事。',
        ],
      },
    ],
  },
];

const skills = [
  {
    category: 'Technical',
    items: ['GA4', 'Looker Studio', 'CDP (mParticle)', 'BigQuery SQL', 'n8n', 'ETL Pipeline', 'Taxonomy Design', 'Figma', 'Claude Code'],
  },
  {
    category: 'Strategic',
    items: ['Strategic Operations', 'Audience Intelligence', 'Stakeholder Management', 'Data Product Strategy', 'Cross-Functional Alignment', 'Operational Framework Design', 'Commercial Narrative', 'Problem Framing', 'Public Communication'],
  },
];
---

<Layout title="履歷 — 杜韋樺" lang="zh" page="resume">

  <!-- Page header -->
  <div class="pt-4 mb-12">
    <p class="section-label mb-4">Resume</p>
    <h1 class="text-5xl font-bold tracking-tight text-[#0a0a0a] leading-none">履歷 <span class="text-zinc-300">Experience</span></h1>
  </div>

  <!-- Experience -->
  <section class="mb-16">
    <div class="rule-strong mb-0">
      {experience.map((job, i) => (
        <div class={`py-10 ${i < experience.length - 1 ? 'border-b border-zinc-100' : ''}`}>

          <!-- Role header -->
          <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1 mb-6">
            <div>
              <h2 class="text-xl font-semibold text-[#0a0a0a]">{job.role}</h2>
              <p class="text-sm text-zinc-500 mt-0.5">{job.company}</p>
            </div>
            <span class="section-label whitespace-nowrap">{job.period}</span>
          </div>

          <!-- Grouped bullets -->
          <div class="space-y-6">
            {job.groups.map(group => (
              <div>
                {group.label && (
                  <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-blue-600 mb-2.5">{group.label}</p>
                )}
                <ul class="space-y-2">
                  {group.items.map(item => (
                    <li class="flex items-start gap-3 text-sm text-zinc-600 leading-relaxed">
                      <span class="mt-2 h-px w-3 bg-zinc-300 shrink-0"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

        </div>
      ))}
    </div>
  </section>

  <!-- Education -->
  <section class="mb-16">
    <div class="rule-strong">
      <div class="py-8 flex flex-col md:flex-row md:items-baseline md:justify-between gap-1">
        <div>
          <p class="section-label mb-3">學歷 Education</p>
          <p class="text-base font-semibold text-[#0a0a0a]">國立台灣大學</p>
          <p class="text-sm text-zinc-500">人類學系／所碩畢</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Awards -->
  <section class="mb-16">
    <div class="rule-strong">
      <div class="py-8">
        <p class="section-label mb-6">獎項 Awards</p>
        <ul class="space-y-4">
          <li class="flex items-start gap-3 text-sm text-zinc-600 leading-relaxed">
            <span class="mt-2 h-px w-3 bg-zinc-300 shrink-0"></span>
            <span><span class="font-medium text-[#0a0a0a]">製片</span>，《踮腳尖》— 入圍第 69 屆柏林影展 K-Plus 兒童短片競賽單元</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-zinc-600 leading-relaxed">
            <span class="mt-2 h-px w-3 bg-zinc-300 shrink-0"></span>
            <span><span class="font-medium text-[#0a0a0a]">製作助理</span>，《日常對話》— 獲第 67 屆柏林影展泰迪熊獎，代表台灣角逐第 90 屆奧斯卡金像獎最佳外語片</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section>
    <div class="rule-strong">
      <div class="py-8">
        <p class="section-label mb-6">技能 Skills</p>
        <div class="space-y-5">
          {skills.map(group => (
            <div class="flex gap-6 items-start">
              <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-zinc-400 w-20 shrink-0 pt-1">
                {group.category}
              </p>
              <div class="flex flex-wrap gap-2">
                {group.items.map(skill => (
                  <span class="px-3 py-1 text-xs font-medium border border-zinc-200 text-zinc-600 rounded-sm hover:border-zinc-400 transition-colors">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

</Layout>
