---
import '../styles/global.css';

interface Props {
  title: string;
  lang: 'zh' | 'en';
  page: 'about' | 'resume' | 'portfolio';
}

const { title, lang, page } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY;
const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST || 'https://us.i.posthog.com';

const nav = {
  zh: [
    { key: 'about',     label: 'ABOUT' },
    { key: 'resume',    label: 'RESUME' },
    { key: 'portfolio', label: 'PORTFOLIO' },
  ],
  en: [
    { key: 'about',     label: 'ABOUT' },
    { key: 'resume',    label: 'RESUME' },
    { key: 'portfolio', label: 'PORTFOLIO' },
  ],
};

const otherLang    = lang === 'zh' ? 'en' : 'zh';
const langLabel    = lang === 'zh' ? 'EN' : '中';
const displayName  = lang === 'zh' ? '杜韋樺' : 'Tu, Wei-Hua';
const pageLabel    = { about: 'About', resume: 'Resume', portfolio: 'Portfolio' }[page];
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-TW' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..700;1,14..32,300..700&family=Noto+Sans+TC:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>

  <body class="min-h-screen flex flex-col bg-white text-[#0a0a0a]">

    <!-- ── Mobile top bar (hidden on lg+) ── -->
    <header class="lg:hidden sticky top-0 z-50 bg-white border-b-2 border-[#0a0a0a] px-6 h-12 flex items-center justify-between">
      <a href={`${base}${lang}/about`}
         class={[
           'font-semibold uppercase hover:text-blue-600 transition-colors',
           lang === 'en' ? 'text-[10px] tracking-[0.08em]' : 'text-xs tracking-[0.12em]',
         ].join(' ')}>
        {displayName}
      </a>
      <div class="flex items-center gap-0">
        {nav[lang].map(({ key, label }) => (
          <a href={`${base}${lang}/${key}`}
             class={[
               'px-3 h-12 flex items-center text-[10px] font-semibold uppercase tracking-[0.1em] transition-colors',
               page === key ? 'text-[#0a0a0a]' : 'text-zinc-400 hover:text-[#0a0a0a]',
             ].join(' ')}>
            {label}
          </a>
        ))}
        <a href={`${base}${otherLang}/${page}`}
           class="px-3 h-12 flex items-center text-[10px] font-semibold uppercase tracking-[0.1em] text-zinc-400 hover:text-[#0a0a0a] transition-colors border-l border-zinc-200 ml-1">
          {langLabel}
        </a>
      </div>
    </header>

    <!-- ── Desktop three-column layout (shown on lg+) ── -->
    <div class="flex-1 flex">

      <!-- Left sidebar: current page label -->
      <aside class="hidden lg:flex shrink-0 w-10 border-r-2 border-[#0a0a0a] flex-col items-center justify-center sticky top-0 h-screen overflow-hidden">
        <span class="[writing-mode:vertical-rl] text-xs font-semibold uppercase tracking-[0.18em] text-[#0a0a0a] whitespace-nowrap">
          {pageLabel}
        </span>
      </aside>

      <!-- Center: main content -->
      <main class="flex-1 min-w-0 px-10 lg:px-16 py-14 lg:py-20">
        <slot />
      </main>

      <!-- Right sidebar: navigation -->
      <aside class="hidden lg:flex shrink-0 w-32 border-l-2 border-[#0a0a0a] flex-col justify-between py-8 px-6 sticky top-0 h-screen">
        <nav class="flex flex-col gap-3">
          {nav[lang].map(({ key, label }) => (
            <a href={`${base}${lang}/${key}`}
               class={[
                 'text-[11px] font-semibold uppercase tracking-[0.12em] transition-colors',
                 page === key ? 'text-[#0a0a0a]' : 'text-zinc-300 hover:text-[#0a0a0a]',
               ].join(' ')}>
              {label}
            </a>
          ))}
        </nav>

        <a href={`${base}${otherLang}/${page}`}
           class="text-[11px] font-semibold uppercase tracking-[0.12em] text-zinc-300 hover:text-[#0a0a0a] transition-colors">
          {langLabel}
        </a>
      </aside>

    </div>

    <!-- Mobile footer -->
    <footer class="lg:hidden border-t-2 border-[#0a0a0a] py-4 px-6">
      <span class="section-label">© 2025 {displayName}</span>
    </footer>

    {posthogKey && (
      <script define:vars={{ posthogKey, posthogHost, page, lang }}>
        const isLocalhost = ['localhost', '127.0.0.1'].includes(window.location.hostname);

        if (!isLocalhost) {
          (function (documentRef, posthogRef) {
            if (posthogRef.__SV) return;
            window.posthog = posthogRef;
            posthogRef._i = [];
            posthogRef.init = function (token, config, name) {
              function stub(target, method) {
                const parts = method.split('.');
                if (parts.length === 2) {
                  target = target[parts[0]];
                  method = parts[1];
                }
                target[method] = function () {
                  target.push([method].concat(Array.prototype.slice.call(arguments, 0)));
                };
              }

              const scriptEl = documentRef.createElement('script');
              scriptEl.type = 'text/javascript';
              scriptEl.crossOrigin = 'anonymous';
              scriptEl.async = true;
              scriptEl.src = config.api_host.replace('.i.posthog.com', '-assets.i.posthog.com') + '/static/array.js';
              const firstScript = documentRef.getElementsByTagName('script')[0];
              firstScript.parentNode.insertBefore(scriptEl, firstScript);

              let instance = posthogRef;
              if (name !== undefined) {
                instance = posthogRef[name] = [];
              }

              instance.people = instance.people || [];
              instance.toString = function (includeStub) {
                let label = 'posthog';
                if (name !== undefined) label += '.' + name;
                if (!includeStub) label += ' (stub)';
                return label;
              };
              instance.people.toString = function () {
                return instance.toString(1) + '.people (stub)';
              };

              'capture register register_once unregister get_distinct_id reset opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing'.split(' ').forEach(function (method) {
                stub(instance, method);
              });

              posthogRef._i.push([token, config, name]);
            };
            posthogRef.__SV = 1;
          })(document, window.posthog || []);

          window.posthog.init(posthogKey, {
            api_host: posthogHost,
            autocapture: false,
            capture_pageview: false,
            capture_pageleave: false,
          });

          const baseProperties = {
            page,
            lang,
            path: window.location.pathname,
          };

          window.posthog.capture('page_view', {
            ...baseProperties,
            title: document.title,
            url: window.location.href,
          });

          document.addEventListener('click', (event) => {
            const target = event.target instanceof Element
              ? event.target.closest('[data-analytics-click]')
              : null;

            if (!target) return;

            window.posthog.capture('click', {
              ...baseProperties,
              click_type: target.getAttribute('data-analytics-click'),
              click_label: target.getAttribute('data-analytics-label') || target.textContent?.trim() || '',
              href: target instanceof HTMLAnchorElement ? target.href : '',
              project_id: target.getAttribute('data-analytics-project') || '',
            });
          });
        }
      </script>
    )}

  </body>
</html>
